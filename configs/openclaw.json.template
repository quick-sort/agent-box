{
  "meta": {
    "lastTouchedVersion": "2026.3.44",
    "lastTouchedAt": "2026-04-03T00:00:00.000Z"
  },
  "update": {
    "checkOnStart": false
  },
  "browser": {
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw",
    "executablePath": "/usr/bin/chromium"
  },
  "models": {
    "mode": "merge",
    "providers": {
      "claude": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": "your-anthropic-api-key",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-5",
            "name": "Claude Sonnet 4.5",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": {
              "input": 3,
              "output": 15,
              "cacheRead": 0.3,
              "cacheWrite": 3.75
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "claude/claude-sonnet-4-5"
      },
      "imageModel": {
        "primary": "claude/claude-sonnet-4-5"
      },
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "elevatedDefault": "full",
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions",
    "tts": {
      "edge": {
        "voice": "zh-CN-XiaoxiaoNeural"
      }
    }
  },
  "channels": {
    "qqbot": {
      "enabled": true,
      "appId": "your-qqbot-app-id",
      "clientSecret": "your-qqbot-client-secret"
    },
    "weixin": {
      "enabled": true,
      "appId": "your-weixin-app-id",
      "appSecret": "your-weixin-app-secret",
      "token": "your-weixin-token",
      "encodingAesKey": "your-weixin-aes-key"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowInsecureAuth": true
    },
    "auth": {
      "mode": "token",
      "token": "your-dev-token-change-me"
    }
  },
  "plugins": {
    "entries": {
      "qqbot": {
        "enabled": true
      },
      "weixin": {
        "enabled": true
      }
    }
  }
}
