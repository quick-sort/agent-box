# ── Claude / LLM ──
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5
# Bedrock / Vertex (set to 1 to enable)
CLAUDE_CODE_USE_BEDROCK=
CLAUDE_CODE_USE_VERTEX=

# ── OpenClaw Channel ──
# qqbot / feishu
OPENCLAW_CHANNEL_TYPE=
OPENCLAW_GATEWAY_TOKEN=

# QQBot
QQBOT_APP_ID=
QQBOT_CLIENT_SECRET=

# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# ── GitHub Runner ──
GITHUB_TOKEN=
GITHUB_RUNNER_REPO=
GITHUB_RUNNER_NAME=agent-box
GITHUB_RUNNER_LABELS=self-hosted,agent-box
